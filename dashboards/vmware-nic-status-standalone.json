{
    "annotations": {
        "list": [
            {
                "builtIn": 1,
                "datasource": {
                    "type": "grafana",
                    "uid": "-- Grafana --"
                },
                "enable": true,
                "hide": true,
                "name": "Annotations & Alerts",
                "type": "dashboard"
            }
        ]
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 0,
    "links": [],
    "panels": [
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "align": "left",
                        "cellOptions": {
                            "type": "auto"
                        },
                        "inspect": false,
                        "filterable": false
                    },
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            }
                        ]
                    },
                    "color": {
                        "mode": "thresholds"
                    },
                    "unit": "none"
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Status"
                        },
                        "properties": [
                            {
                                "id": "mappings",
                                "value": [
                                    {
                                        "options": {
                                            "0": {
                                                "color": "red",
                                                "index": 0,
                                                "text": "DOWN"
                                            },
                                            "1": {
                                                "color": "green",
                                                "index": 1,
                                                "text": "UP"
                                            }
                                        },
                                        "type": "value"
                                    }
                                ]
                            },
                            {
                                "id": "custom.cellOptions",
                                "value": {
                                    "type": "color-background"
                                }
                            },
                            {
                                "id": "custom.align",
                                "value": "center"
                            }
                        ]
                    },
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Speed"
                        },
                        "properties": [
                            {
                                "id": "mappings",
                                "value": [
                                    {
                                        "options": {
                                            "Unknown": {
                                                "color": "red",
                                                "index": 0,
                                                "text": "DOWN"
                                            }
                                        },
                                        "type": "value"
                                    }
                                ]
                            },
                            {
                                "id": "custom.align",
                                "value": "center"
                            }
                        ]
                    }
                ]
            },
            "gridPos": {
                "h": 12,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "id": 1,
            "interval": "20s",
            "options": {
                "showHeader": true,
                "cellHeight": "sm",
                "footer": {
                    "show": false,
                    "reducer": [
                        "sum"
                    ],
                    "countRows": false,
                    "fields": "",
                    "enablePagination": false
                },
                "sortBy": []
            },
            "pluginVersion": "10.4.11",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "editorMode": "code",
                    "expr": "max(vmware_host_nic_link_status{vcenter=~\"$vcenter\", host=~\"$host\"}) by (device, speed)",
                    "format": "table",
                    "instant": true,
                    "refId": "A"
                }
            ],
            "title": "Physical NIC Status & Speed",
            "transformations": [
                {
                    "id": "organize",
                    "options": {
                        "excludeByName": {
                            "Time": true
                        },
                        "indexByName": {
                            "device": 0,
                            "speed": 1,
                            "Value": 2
                        },
                        "renameByName": {
                            "Value": "Status",
                            "device": "NIC Name",
                            "speed": "Speed"
                        }
                    }
                }
            ],
            "type": "table"
        }
    ],
    "refresh": "30s",
    "schemaVersion": 39,
    "templating": {
        "list": [
            {
                "name": "datasource",
                "query": "prometheus",
                "refresh": 1,
                "type": "datasource"
            },
            {
                "datasource": {
                    "type": "prometheus",
                    "uid": "${datasource}"
                },
                "definition": "label_values(vmware_host_info, vcenter)",
                "name": "vcenter",
                "query": {
                    "query": "label_values(vmware_host_info, vcenter)"
                },
                "refresh": 1,
                "type": "query"
            },
            {
                "datasource": {
                    "type": "prometheus",
                    "uid": "${datasource}"
                },
                "definition": "label_values(vmware_host_info{vcenter=~\"$vcenter\"}, host)",
                "name": "host",
                "query": {
                    "query": "label_values(vmware_host_info{vcenter=~\"$vcenter\"}, host)"
                },
                "refresh": 1,
                "type": "query"
            }
        ]
    },
    "title": "VMware NIC Status",
    "uid": "vmw-nic-status-final",
    "version": 1
}